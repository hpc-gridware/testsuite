##
# @file check.exp
# @brief Long-running multi-day dbwriter integration test (CS-2232).
#
# Long-running integration test for the dbwriter. Over several (real or -
# in fast mode - collapsed) days it exercises the derived-value rules, the
# deletion rules and a mixed multi-user workload, and verifies the resulting
# ARCO database content.
#
# This file currently contains the shared scaffolding (CS-2233): the
# setup/cleanup functions and a scaffolding self-test. The workload and the
# per-phase assertions are added by the follow-up sub-tasks CS-2234 .. CS-2240.
#
# @see dbwriter_long_lib.tcl

# define global variables in this namespace
# note: check_setup_function / check_cleanup_function are pre-created as local
# variables by the framework before this file is sourced, so they must not be
# declared "global" here - they are just "set" below, like in the other tests.
global check_name
global check_category
global check_description
global check_needs
global check_functions
global check_root_access_needs
global check_version_range

# the long-running test runs jobs as several users, including root
set check_root_access_needs "yes"

# the workload uses JSONL reporting and online_usage records (since 9.1.2)
set check_version_range "9.1.2"

# define test's name and run level descriptions
set check_name           "arco_dbwriter_long_running"
set check_category       "DBWRITER VERIFIED"
set check_description(0)   "long-running multi-day dbwriter integration test - just checking scaffolding"
set check_description(400) "long-running multi-day dbwriter integration test"

# define test's dependencies
set check_needs          "init_core_system arco_database_install arco_dbwriter_install"

# setup and cleanup functions
set check_setup_function   "dbwriter_long_running_setup"
set check_cleanup_function "dbwriter_long_running_cleanup"

# define test's procedure order
# CS-2233 ships the scaffolding self-test (run level 0); CS-2241 adds the
# Phase C check, CS-2235 adds the Phase D raw-data check (both at run level
# 400); CS-2236 .. CS-2239 append the hourly/daily derived and deletion-rule
# phase functions here.
set check_functions {}
lappend check_functions "dbwriter_long_running_scaffolding"
lappend check_functions "dbwriter_long_running_phase_c"
lappend check_functions "dbwriter_long_running_phase_d"

# source the shared scaffolding library (dbwriter_xml / db / dbwriter_long)
# and the job-load generator (workload)
global CHECK_ACTUAL_TEST_PATH
ts_source "$CHECK_ACTUAL_TEST_PATH/dbwriter_long_lib"
ts_source "$CHECK_ACTUAL_TEST_PATH/dbwriter_long_workload"

# -------- setup / cleanup ------------------------------------------------------

##
# @brief Prepare the long-running test - bring the cluster to a known state.
#
# Brings the cluster into a known-empty starting state and applies the
# configuration shared by all workload phases:
#   - backs up the global cluster configuration,
#   - backs up the active dbwriter.xml calculation file,
#   - stops the dbwriter if it is running,
#   - empties all ARCO database tables via arco_clean_database,
#   - raises the exec host slot capacity for the test host,
#   - enables qmaster reporting,
#   - creates the tight-integration PE and queue,
#   - creates the test project,
#   - starts the dbwriter.
#
# The reporting configuration, the PE/queue and the running dbwriter are
# needed by every workload phase, not only by Phase C, so they are set up
# here and not in a phase function - keeping the setup and cleanup functions
# symmetrical.
#
# The dbwriter installation and the database schema are already created by
# the testsuite installation, so nothing is installed here.
#
# @return 0 on success, else -1 (error reported via ts_log_severe)
proc dbwriter_long_running_setup {} {
   global dbwriter_long_config_backup
   global dbwriter_long_test_host
   global dbwriter_long_online_usage_vars
   global dbwriter_long_report_variables

   # online_usage usage variables enabled for the test - used both when
   # enabling reporting and when asserting the online_usage fan-out
   set dbwriter_long_online_usage_vars {cpu mem maxvmem wallclock}

   # host load variables Phase D expects in sge_host_values. The same list is
   # written into report_variables on the global exec host when reporting is
   # enabled.
   set dbwriter_long_report_variables {cpu np_load_avg mem_free virtual_free}

   # back up the global configuration - the workload phases enable reporting
   get_config dbwriter_long_config_backup

   # back up the dbwriter calculation file - the deletion-rule phase edits it
   if {[dbwriter_xml::backup] != 0} {
      return -1
   }

   # stop the dbwriter so the database can be emptied without a race
   if {[get_dbwriter_status 0] == 0} {
      if {[shutdown_dbwriter] != 0} {
         ts_log_severe "can not stop dbwriter"
         return -1
      }
   }

   # start from a known-empty database
   if {[arco_clean_database] < 0} {
      ts_log_severe "can not clean the ARCO database"
      return -1
   }

   # a host for the test PE / queue - remembered so the cleanup function can
   # remove the PE and queue again
   set dbwriter_long_test_host [host_conf_get_suited_hosts]

   # raise the exec host slot capacity - the core-binding default slot count
   # of the exec host can be lower than the workload needs
   setup_host_slots_for_binding $dbwriter_long_test_host

   # enable qmaster reporting (accounting, reporting, joblog, online_usage, ...)
   if {[dbwriter_long_enable_reporting] != 0} {
      return -1
   }

   # create the tight-integration PE and queue used by the workload PE jobs
   if {[workload::setup_pe_queue $dbwriter_long_test_host] != 0} {
      return -1
   }

   # create the project the workload jobs run under
   if {[workload::setup_project] != 0} {
      return -1
   }

   # start the dbwriter
   if {[get_dbwriter_status 0] != 0} {
      if {[startup_dbwriter] != 0} {
         ts_log_severe "dbwriter long test: can not start the dbwriter"
         return -1
      }
   }

   return 0
}

##
# @brief Restore the environment after the long-running test.
#
# Reverts everything dbwriter_long_running_setup and the phases changed:
#   - closes the db connection,
#   - deletes leftover jobs,
#   - removes the test PE and queue,
#   - removes the test project,
#   - restores the exec host slot capacity,
#   - stops the dbwriter,
#   - restores the original dbwriter.xml and global configuration,
#   - empties the ARCO database again.
#
# dbwriter_xml::restore is idempotent, so aborting the test mid-run still
# leaves the environment in its original state.
#
# @return 0
proc dbwriter_long_running_cleanup {} {
   global dbwriter_long_config_backup
   global dbwriter_long_exechost_backup
   global dbwriter_long_test_host

   db::disconnect

   delete_all_jobs
   wait_for_end_of_all_jobs 60

   # remove the test PE and queue and restore the exec host slot capacity
   if {[info exists dbwriter_long_test_host]} {
      workload::cleanup_pe_queue $dbwriter_long_test_host
      cleanup_host_slots_for_binding
      unset dbwriter_long_test_host
   }

   # remove the test project
   workload::cleanup_project

   if {[get_dbwriter_status 0] == 0} {
      shutdown_dbwriter
   }

   # restore the original dbwriter calculation file
   dbwriter_xml::restore

   # restore the global configuration
   if {[info exists dbwriter_long_config_backup]} {
      reset_config dbwriter_long_config_backup
      unset dbwriter_long_config_backup
   }

   # restore report_variables on the global exec host
   if {[info exists dbwriter_long_exechost_backup]} {
      set_exechost dbwriter_long_exechost_backup global
      array unset dbwriter_long_exechost_backup
   }

   # leave the database empty
   arco_clean_database

   # drop every global variable this test introduces so a follow-up test in
   # the same testsuite run starts from a clean slate
   unset -nocomplain ::dbwriter_long_config_backup
   unset -nocomplain ::dbwriter_long_exechost_backup
   unset -nocomplain ::dbwriter_long_online_usage_vars
   unset -nocomplain ::dbwriter_long_report_variables
   unset -nocomplain ::dbwriter_long_test_host

   return 0
}

# -------- scaffolding self-test ------------------------------------------------

##
# @brief Verify the shared scaffolding (CS-2233 scaffolding self-test).
#
# Self-test for the CS-2233 scaffolding. It verifies, without a real-time
# wait, that the shared helpers work before the workload phases rely on them:
#   - dbwriter_xml::read parses the active dbwriter.xml,
#   - dbwriter_long::register_short_retention_rules rewrites the deletion
#     rules and dbwriter_xml::get_delete_rule reads them back,
#   - dbwriter_xml::restore puts the original rules back,
#   - the db wrapper connects, queries and disconnects,
#   - dbwriter_long_running_setup left the ARCO tables empty.
#
# @return 0 if the scaffolding is OK, else -1 (error reported via ts_log_severe)
proc dbwriter_long_running_scaffolding {} {
   global CHECK_ACT_LEVEL check_description

   if {$CHECK_ACT_LEVEL != 0} {
      return 0
   }
   ts_log_fine $check_description($CHECK_ACT_LEVEL)

   # ---- dbwriter_xml: the active calculation file parses --------------------
   set doc [dbwriter_xml::read]
   if {$doc eq ""} {
      return -1
   }
   set root [$doc documentElement]
   set n_derive [llength [$root selectNodes {//derive}]]
   set n_delete [llength [$root selectNodes {//delete}]]
   $doc delete
   if {$n_derive == 0 || $n_delete == 0} {
      ts_log_severe "dbwriter.xml has $n_derive derive and $n_delete delete rules, expected both > 0"
      return -1
   }
   ts_log_fine "dbwriter.xml parsed: $n_derive derive rules, $n_delete delete rules"

   # ---- dbwriter_xml: short-retention rules can be written and read back ----
   if {[dbwriter_long::register_short_retention_rules] != 0} {
      return -1
   }
   foreach {scope sub_scopes expected} {
      job              {}                                       {day 2}
      online_usage     {}                                       {day 1}
      host_values      {np_load_avg cpu mem_free virtual_free}   {day 1}
   } {
      set got [dbwriter_xml::get_delete_rule $scope $sub_scopes]
      if {$got ne $expected} {
         ts_log_severe "delete rule $scope: expected {$expected}, got {$got}"
         return -1
      }
   }
   ts_log_fine "short-retention deletion rules written and verified"

   # ---- dbwriter_xml: the original rules are restored -----------------------
   if {[dbwriter_xml::restore] != 0} {
      return -1
   }
   set got [dbwriter_xml::get_delete_rule "job"]
   if {$got ne {year 1}} {
      ts_log_severe "dbwriter.xml restore failed: job rule is {$got}, expected {year 1}"
      return -1
   }
   ts_log_fine "original dbwriter.xml restored"

   # ---- db: connect, query, disconnect --------------------------------------
   if {[db::connect] != 0} {
      return -1
   }
   # sge_version is populated by the schema install and is never cleaned
   set n_version [db::count "sge_version"]
   if {$n_version < 1} {
      ts_log_severe "db::count sge_version returned $n_version, expected >= 1"
      db::disconnect
      return -1
   }
   # setup ran arco_clean_database, so the job table must be empty
   set n_job [db::count "sge_job"]
   db::disconnect
   if {$n_job != 0} {
      ts_log_severe "ARCO database not empty after setup: sge_job has $n_job rows"
      return -1
   }
   ts_log_fine "db wrapper OK (sge_version rows: $n_version, sge_job rows: $n_job)"

   ts_log_fine "dbwriter long-running scaffolding self-test passed"
   return 0
}

# -------- Phase C: first-hour workload + per-job record assertions -------------

##
# @brief Enable qmaster reporting for the long-running test.
#
# Enables accounting, reporting, joblog, online_usage and consumable logging
# with a short flush time, and shortens load_report_time so host load and
# online_usage records accrue quickly. Sets report_variables on the global
# exec host so the load variables Phase D checks are written to the reporting
# file. Called from dbwriter_long_running_setup; the pre-test cluster
# configuration was saved there, and the previous report_variables value is
# saved here. Both are restored by dbwriter_long_running_cleanup.
#
# @return 0 on success, else -1 (error reported via ts_log_severe)
proc dbwriter_long_enable_reporting {} {
   global dbwriter_long_online_usage_vars
   global dbwriter_long_report_variables
   global dbwriter_long_exechost_backup

   # online_usage is a JSONL-only record type - the long-running test keeps
   # the qmaster on the default (JSONL) reporting format, so it is not changed
   set d " "
   get_config conf
   add_or_replace_array_param new conf reporting_params "accounting"      "true"     $d
   add_or_replace_array_param new new  reporting_params "reporting"       "true"     $d
   add_or_replace_array_param new new  reporting_params "joblog"          "true"     $d
   add_or_replace_array_param new new  reporting_params "flush_time"      "00:00:04" $d
   add_or_replace_array_param new new  reporting_params "log_consumables" "true"     $d
   add_or_replace_array_param new new  reporting_params "online_usage" \
      [join $dbwriter_long_online_usage_vars "|"] $d
   # frequent load reports so host_values and online_usage accrue quickly
   set new(load_report_time) "00:00:15"
   set_config new

   # configure host-level reporting of the raw load variables Phase D verifies.
   # Save the previous report_variables value so cleanup can put it back; the
   # value defaults to "NONE" on a freshly installed cluster but a preceding
   # scenario may have left a different value.
   if {[get_exechost global_host global] != 0} {
      ts_log_severe "dbwriter long test: can not read the global exec host config"
      return -1
   }
   set dbwriter_long_exechost_backup(report_variables) \
      $global_host(report_variables)
   set chgar(report_variables) [join $dbwriter_long_report_variables ","]
   if {[set_exechost chgar global] != 0} {
      ts_log_severe "dbwriter long test: can not set report_variables on the\
                     global exec host"
      return -1
   }

   ts_log_fine "dbwriter long test: qmaster reporting enabled (report_variables\
                = $chgar(report_variables))"
   return 0
}

##
# @brief Assert the per-job records of the first-hour workload.
#
# Polls the database until the dbwriter has imported the accounting records,
# then asserts that the first-hour workload is correctly recorded: the exact
# expected number of sge_job and sge_job_usage rows (overall and per user),
# non-empty sge_job_log and sge_job_request, and sge_job_online_usage rows that
# fan out one per configured usage variable.
#
# @return 0 if all assertions pass, else -1 (error reported via ts_log_severe)
proc dbwriter_long_phase_c_assert_jobs {} {
   global dbwriter_long_online_usage_vars

   set per_user     [workload::expected_finished_per_user]
   set job_per_user [workload::expected_job_rows_per_user]
   set users        [workload::users]
   set expected     [expr {$per_user * [llength $users]}]
   set job_expected [expr {$job_per_user * [llength $users]}]

   if {[db::connect] != 0} {
      return -1
   }

   # poll until the dbwriter has imported all accounting records
   set deadline [expr {[clock seconds] + 300}]
   while {1} {
      set n_usage [db::count "sge_job_usage"]
      if {$n_usage >= $expected} {
         break
      }
      if {[clock seconds] >= $deadline} {
         ts_log_severe "dbwriter long test: only $n_usage of $expected accounting\
                        records were imported within the timeout"
         db::disconnect
         return -1
      }
      ts_log_fine "dbwriter long test: waiting for accounting import\
                   ($n_usage/$expected)"
      sleep_for_seconds 15
   }

   set rc 0

   # exactly the expected number of accounting records and job rows
   if {$n_usage != $expected} {
      ts_log_severe "dbwriter long test: sge_job_usage has $n_usage rows,\
                     expected exactly $expected"
      set rc -1
   }
   set n_job [db::count "sge_job"]
   if {$n_job != $job_expected} {
      ts_log_severe "dbwriter long test: sge_job has $n_job rows, expected $job_expected"
      set rc -1
   }

   # per-user breakdown of sge_job
   foreach user $users {
      set n [db::count "sge_job" "j_owner = '$user'"]
      if {$n != $job_per_user} {
         ts_log_severe "dbwriter long test: user $user has $n rows in sge_job,\
                        expected $job_per_user"
         set rc -1
      }
   }

   # job log and job request rows must exist
   foreach table {sge_job_log sge_job_request} {
      set n [db::count $table]
      if {$n <= 0} {
         ts_log_severe "dbwriter long test: $table is empty, expected rows"
         set rc -1
      }
   }

   # online_usage: rows present, fanned out one per configured usage variable
   set n_ou [db::count "sge_job_online_usage"]
   if {$n_ou <= 0} {
      ts_log_severe "dbwriter long test: sge_job_online_usage is empty"
      set rc -1
   } else {
      array set r {}
      set cols {}
      if {[db::query "SELECT COUNT(DISTINCT jou_variable) FROM sge_job_online_usage" \
              r cols] < 0} {
         set rc -1
      } else {
         set want [llength $dbwriter_long_online_usage_vars]
         if {$r(0,0) != $want} {
            ts_log_severe "dbwriter long test: sge_job_online_usage has $r(0,0)\
                           distinct variables, expected $want"
            set rc -1
         }
      }
   }

   db::disconnect
   if {$rc == 0} {
      ts_log_fine "dbwriter long test: per-job record assertions passed\
                   ($expected accounting records)"
   }
   return $rc
}

##
# @brief Create an advance reservation, run a job in it and assert sge_ar*.
#
# @param host the host whose queue the AR reserves and the AR job runs on
# @return 0 if the sge_ar* tables are correctly populated, else -1
proc dbwriter_long_phase_c_check_ar {host} {
   global CHECK_USER

   set ar_id [workload::create_ar $host]
   if {$ar_id <= 0} {
      return -1
   }
   set ar_job [workload::submit_into_ar $ar_id $CHECK_USER $host]
   if {$ar_job <= 0} {
      workload::delete_ar_reservation $ar_id
      return -1
   }
   if {[wait_for_end_of_all_jobs 300] != 0} {
      ts_log_severe "dbwriter long test: the AR job did not finish in time"
      workload::delete_ar_reservation $ar_id
      return -1
   }
   # delete the AR so its final state change is logged as well
   workload::delete_ar_reservation $ar_id

   if {[db::connect] != 0} {
      return -1
   }

   # the dbwriter imports a record some time after qmaster writes it, and the
   # parent sge_ar row appears before its sub-records - so wait for each table
   # to be populated rather than reading the counts once
   #
   # sge_ar_resource_usage is intentionally not checked yet: the test AR
   # requests no resources, so that table stays empty. It is to be added once
   # workload::create_ar submits the AR with a resource request.
   set rc 0
   foreach table {sge_ar sge_ar_attribute sge_ar_usage sge_ar_log} {
      if {[db::wait_for_rows $table] != 0} {
         ts_log_severe "dbwriter long test: $table is empty after the AR run"
         set rc -1
      }
   }

   db::disconnect
   if {$rc == 0} {
      ts_log_fine "dbwriter long test: advance-reservation tables populated"
   }
   return $rc
}

##
# @brief Phase C - run the first-hour workload and assert the per-job records.
#
# Runs at check run level 400. Runs the first-hour deterministic workload
# (workload::run_first_hour) and an advance reservation, and asserts that every
# job and the AR are correctly recorded in the ARCO database. The test host,
# the PE/queue, qmaster reporting and the running dbwriter are prepared by
# dbwriter_long_running_setup.
#
# @return 0 if Phase C passed, else -1 (error reported via ts_log_severe)
proc dbwriter_long_running_phase_c {} {
   global CHECK_ACT_LEVEL check_description
   global dbwriter_long_test_host

   if {$CHECK_ACT_LEVEL != 400} {
      return 0
   }
   ts_log_fine $check_description(400)

   # the test host, PE/queue, qmaster reporting and the dbwriter were prepared
   # by dbwriter_long_running_setup
   set host $dbwriter_long_test_host

   # Phase C: run the first-hour deterministic workload
   if {[workload::run_first_hour $host] != 0} {
      return -1
   }

   # assert every job of the first-hour workload is correctly recorded
   if {[dbwriter_long_phase_c_assert_jobs] != 0} {
      return -1
   }

   # advance reservation: create one, run a job in it, assert the sge_ar* tables
   if {[dbwriter_long_phase_c_check_ar $host] != 0} {
      return -1
   }

   ts_log_fine "dbwriter long test: Phase C passed"
   return 0
}

# -------- Phase D: raw-data assertions -----------------------------------------

##
# @brief Poll the database until every report_variable has a host_values row.
#
# The execd sends a load report every load_report_time seconds and the dbwriter
# imports it some seconds later, so an assertion immediately after Phase C may
# race the first load report. This helper polls until every variable listed in
# dbwriter_long_report_variables has at least one row in sge_host_values, or
# the timeout expires. The actual assertion happens in the caller.
#
# Once a variable has been seen once, dbwriter only adds further rows for it;
# the helper therefore stops re-querying variables it has already found.
#
# @param timeout seconds to wait before giving up
proc dbwriter_long_phase_d_wait_for_host_values {timeout} {
   global dbwriter_long_report_variables

   set deadline [expr {[clock seconds] + $timeout}]
   set missing $dbwriter_long_report_variables
   while {[llength $missing] > 0} {
      set still_missing {}
      foreach var $missing {
         if {[db::count "sge_host_values" "hv_variable = '$var'"] <= 0} {
            lappend still_missing $var
         }
      }
      set missing $still_missing
      if {[llength $missing] == 0 || [clock seconds] >= $deadline} {
         return
      }
      ts_log_fine "dbwriter long test: waiting for sge_host_values rows\
                   (missing: $missing)"
      sleep_for_seconds 15
   }
}

##
# @brief Assert the raw load and consumable value rows produced by the workload.
#
# Checks the raw-value tables the parent task lists for Phase D:
#   - sge_host_values: one assertion per variable in
#     dbwriter_long_report_variables (cpu, np_load_avg, mem_free, virtual_free)
#     - each variable must have at least one row.
#   - sge_queue_values: one assertion that the 'slots' consumable was reported.
#   - sge_job, sge_job_request, sge_job_usage, sge_job_log, sge_job_online_usage:
#     non-empty. Phase C asserts exact counts and a per-user breakdown for
#     these tables; the non-emptiness assertion here is the per-table check the
#     sub-task lists and guards against a regression that wipes a whole table
#     between Phase C and Phase D.
#
# @return 0 if every assertion passes, else -1 (errors reported via ts_log_severe)
proc dbwriter_long_phase_d_assert_raw_data {} {
   global dbwriter_long_report_variables

   if {[db::connect] != 0} {
      return -1
   }

   # give the dbwriter time to import the first load reports - Phase C only
   # waits for the accounting records, so a few load reports may still be in
   # flight
   dbwriter_long_phase_d_wait_for_host_values 300

   set rc 0

   # sge_host_values: one assertion per configured report variable
   foreach var $dbwriter_long_report_variables {
      set n [db::count "sge_host_values" "hv_variable = '$var'"]
      if {$n <= 0} {
         ts_log_severe "dbwriter long test: sge_host_values has no rows for\
                        variable '$var' - check report_variables on the global\
                        exec host and load_report_time in reporting_params"
         set rc -1
      } else {
         ts_log_fine "dbwriter long test: sge_host_values has $n rows for $var"
      }
   }

   # sge_queue_values: the 'slots' consumable, driven by log_consumables
   set n [db::count "sge_queue_values" "qv_variable = 'slots'"]
   if {$n <= 0} {
      ts_log_severe "dbwriter long test: sge_queue_values has no rows for\
                     variable 'slots' - check log_consumables in reporting_params"
      set rc -1
   } else {
      ts_log_fine "dbwriter long test: sge_queue_values has $n rows for slots"
   }

   # job-related raw tables: non-emptiness guard. Phase C already asserts exact
   # counts and per-user breakdowns, so any failure here is a regression that
   # wiped a table after Phase C, not a missing record from the workload.
   foreach table {sge_job sge_job_request sge_job_usage sge_job_log \
                  sge_job_online_usage} {
      set n [db::count $table]
      if {$n <= 0} {
         ts_log_severe "dbwriter long test: $table is empty after the first-hour\
                        workload"
         set rc -1
      } else {
         ts_log_fine "dbwriter long test: $table has $n rows"
      }
   }

   db::disconnect
   return $rc
}

##
# @brief Phase D - assert the raw load, consumable and job value tables.
#
# Runs at check run level 400 after Phase C. Phase C submitted and finished
# the first-hour deterministic workload, so by the time Phase D runs the
# dbwriter has received load reports (load_report_time = 15s), consumable
# reports (log_consumables = true) and per-job accounting and usage records.
# Phase D asserts that the corresponding raw-value tables actually contain
# rows.
#
# Acceptance (CS-2235): reverting any single reporting toggle - report_variables
# on the exec host, log_consumables in reporting_params, or online_usage in
# reporting_params - turns the matching assertion red with a useful message.
#
# @return 0 if Phase D passed, else -1 (errors reported via ts_log_severe)
proc dbwriter_long_running_phase_d {} {
   global CHECK_ACT_LEVEL

   if {$CHECK_ACT_LEVEL != 400} {
      return 0
   }
   ts_log_fine "dbwriter long test: Phase D - raw-data assertions"

   if {[dbwriter_long_phase_d_assert_raw_data] != 0} {
      return -1
   }

   ts_log_fine "dbwriter long test: Phase D passed"
   return 0
}
