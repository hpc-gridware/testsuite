# define global variable in this namespace
global check_name
global check_category
global check_description
global check_needs
global check_functions
global check_root_access_needs

set check_root_access_needs "yes"

# define test's name and run level descriptions
set check_name            "sge_share_mon"
set check_category        "SCHEDULER SHARETREE VERIFIED"
set check_description(0)  "test sge_share_mon without sharetree"
set check_description(1)  "test sge_share_mon with sharetree"

# define test's dependencies
set check_needs           "init_core_system"

# setup and cleanup functions
set check_setup_level_function sge_share_mon_setup
set check_cleanup_level_function sge_share_mon_cleanup


# define test's procedure order
set check_functions ""
lappend check_functions "share_mon_sharetree"
lappend check_functions "share_mon_permissions"
lappend check_functions "share_mon_usage_time_stamp"
lappend check_functions "share_mon_usage_in_spool"

# -------- local test procedures: initialization------------------------------

proc sge_share_mon_setup  {} {
   global ts_config
   global CHECK_ACT_LEVEL
   global CHECK_USER CHECK_FIRST_FOREIGN_SYSTEM_USER CHECK_SECOND_FOREIGN_SYSTEM_USER
   global have_share_tree submitted_jobs sge_share_mon_backup

   switch -- $CHECK_ACT_LEVEL {
      0 {
         set have_share_tree 0
      }
      1 {
         set have_share_tree 1
      }
   }

   # here we remember the job ids of submitted jobs to be able
   # to wait until they really left qmaster in the cleanup method
   # required to be able to delete the sharetree and the users
   set submitted_jobs {}

   # make sure there is no sharetree in the beginning
   del_sharetree
   # delete the users as well, they might contain spooled usage from an earlier test
   del_user $CHECK_USER "" "" 0
   del_user $CHECK_FIRST_FOREIGN_SYSTEM_USER "" "" 0
   del_user $CHECK_SECOND_FOREIGN_SYSTEM_USER "" "" 0

   # delete the mytestproject and re-add it to make sure there is no old usage spooled
   del_project "mytestproject"
   add_project "mytestproject"

   if {$have_share_tree} {
      # we want to reference the CHECK_USER in a sharetree
      add_user $CHECK_USER

      # makes sure, sge_schedd knows about deletion of users
      trigger_scheduling

      # create a sharetree
      stree_buffer_init stree
      stree_buffer_add_node stree "/default" 10
      stree_buffer_add_node stree "/$CHECK_USER" 20
      stree_buffer_add_node stree "/mytestproject" 30
      stree_buffer_add_node stree "/mytestproject/default" 40
      stree_buffer_add_node stree "/mytestproject/$CHECK_USER" 50
      stree_buffer_commit stree
   }

   # STREE_SPOOL_INTERVAL=1 so share_mon_usage_in_spool can inspect spooled
   # user/project objects within the test's runtime instead of waiting the
   # 240 s default cadence.
   get_config sge_share_mon_backup
   if {[is_version_in_range "9.2.0"]} {
      add_or_replace_array_param conf sge_share_mon_backup "qmaster_params" "STREE_TICK_INTERVAL" "1"
      add_or_replace_array_param conf conf "qmaster_params" "STREE_SPOOL_INTERVAL" "1"
   } else {
      add_or_replace_array_param conf sge_share_mon_backup "qmaster_params" "STREE_SPOOL_INTERVAL" "1"
   }

   set_config conf
}

proc sge_share_mon_cleanup  {} {
   global ts_config
   global CHECK_USER CHECK_FIRST_FOREIGN_SYSTEM_USER CHECK_SECOND_FOREIGN_SYSTEM_USER
   global have_share_tree submitted_jobs sge_share_mon_backup

   delete_all_jobs
   wait_for_end_of_all_jobs

   reset_config sge_share_mon_backup

   if {$have_share_tree} {
      del_sharetree
      del_user $CHECK_USER
      del_user $CHECK_FIRST_FOREIGN_SYSTEM_USER
      del_user $CHECK_SECOND_FOREIGN_SYSTEM_USER

      # makes sure, sge_schedd knows about deletion of users and sharetree
      trigger_scheduling
   }

   unset -nocomplain have_share_tree submitted_jobs sge_share_mon_backup
}

#****** sge_share_mon/share_mon_sharetree_check_node() ******************************
#  NAME
#     share_mon_sharetree_check_node() -- check modes delivered by sge_share_mon
#
#  SYNOPSIS
#     share_mon_sharetree_check_node { sharetree_var node exists {shares -1} }
#
#  FUNCTION
#     Checks if certain nodes exist / do not exist in sge_share_mon output.
#     Validates, if they contain the correct number of shares.
#
#  INPUTS
#     sharetree_var - the sharetree given by sge_share_mon
#     node          - name of the node to test
#     exists        - do we expect the node to exist (1) or not (0)
#     {shares -1}   - expected number of shares. -1 means: do not check
#
#  RESULT
#     No return code. Errors are reported via ts_log_severe
#     sge_sharetree/sge_share_mon()
#*******************************************************************************
proc share_mon_sharetree_check_node {sharetree_var node exists {shares -1} {expect_actual_share 0}} {
   global ts_config

   upvar $sharetree_var sharetree

   set pos [lsearch -exact $sharetree(index) $node]

   # expect that node exists, but didn't find it?
   if {$exists && $pos < 0} {
      ts_log_severe "couldn't find node $node in sge_share_mon output"
   }

   # expect that node does not exists, but found it?
   if {!$exists && $pos >= 0} {
      ts_log_severe "found node $node in sge_share_mon output, which was not expected to be there"
   }

   # verify if the shares are reported correctly
   if {$exists && $pos >= 0 && $shares >= 0} {
      if {$sharetree($node,shares) != $shares} {
         ts_log_severe "node $node in sge_share_mon output contains incorrect shares:\nexpected $shares, but sge_share_mon reported $sharetree($node,shares)"
      }
   }

   # verify if the actual share is reported correctly
   if {$exists && $pos >= 0 && $expect_actual_share} {
      if {$sharetree($node,actual_share) == 0.0} {
         ts_log_severe "node $node in sge_share_mon output contains incorrect actual share:\nexpected a value > 0, but sge_share_mon reported $sharetree($node,actual_share)"
      }
   }
}

#****** sge_share_mon/share_mon_sharetree() *****************************************
#  NAME
#     share_mon_sharetree() -- test if sge_share_mon deliveres correct data
#
#  SYNOPSIS
#     share_mon_sharetree { }
#
#  FUNCTION
#     Tests, if the sharetree setup in the check setup function is reported correctly
#     by sge_share_mon.
#     Jobs are submitted under user id's handled by the "default" sharetree node and
#     verified that nodes are created under default for these users.
#*******************************************************************************
proc share_mon_sharetree {} {
   global ts_config
   global CHECK_USER CHECK_FIRST_FOREIGN_SYSTEM_USER CHECK_SECOND_FOREIGN_SYSTEM_USER
   global have_share_tree
   global submitted_jobs

   if {!$have_share_tree} {
      # sge_share_mon must fail with an error message
      set result [sge_share_mon sharetree "" "" 0]
      if {$result != -1} {
         ts_log_severe "sge_share_mon should have reported \"No share tree\""
      }
   } else {
      # call sge_share_mon
      sge_share_mon sharetree

      # the following nodes must be contained in share_mon output:
      share_mon_sharetree_check_node sharetree "/" 1
      share_mon_sharetree_check_node sharetree "/default" 1 10
      share_mon_sharetree_check_node sharetree "/$CHECK_USER" 1 20
      share_mon_sharetree_check_node sharetree "/mytestproject" 1 30
      share_mon_sharetree_check_node sharetree "/mytestproject/default" 1 40
      share_mon_sharetree_check_node sharetree "/mytestproject/$CHECK_USER" 1 50

      # the following nodes shall not yet be contained in share_mon output:
      share_mon_sharetree_check_node sharetree "/default/$CHECK_FIRST_FOREIGN_SYSTEM_USER" 0
      share_mon_sharetree_check_node sharetree "/default/$CHECK_SECOND_FOREIGN_SYSTEM_USER" 0
      share_mon_sharetree_check_node sharetree "/mytestproject/default/$CHECK_FIRST_FOREIGN_SYSTEM_USER" 0
      share_mon_sharetree_check_node sharetree "/mytestproject/default/$CHECK_SECOND_FOREIGN_SYSTEM_USER" 0

      # now run jobs as the different users
      set args "$ts_config(product_root)/examples/jobs/sleeper.sh 10"
      set job_id [submit_job $args 1 60 "" $CHECK_USER]
      wait_for_jobstart $job_id "" 5
      lappend submitted_jobs $job_id
      set job_id [submit_job $args 1 60 "" $CHECK_FIRST_FOREIGN_SYSTEM_USER]
      wait_for_jobstart $job_id "" 5
      lappend submitted_jobs $job_id
      set job_id [submit_job $args 1 60 "" $CHECK_SECOND_FOREIGN_SYSTEM_USER]
      wait_for_jobstart $job_id "" 5
      lappend submitted_jobs $job_id

      # now we shall have the first/second foreign user under the default nodes
      sge_share_mon sharetree
      share_mon_sharetree_check_node sharetree "/default/$CHECK_FIRST_FOREIGN_SYSTEM_USER" 1 10
      share_mon_sharetree_check_node sharetree "/default/$CHECK_SECOND_FOREIGN_SYSTEM_USER" 1 10
      share_mon_sharetree_check_node sharetree "/mytestproject/default/$CHECK_FIRST_FOREIGN_SYSTEM_USER" 1 40
      share_mon_sharetree_check_node sharetree "/mytestproject/default/$CHECK_SECOND_FOREIGN_SYSTEM_USER" 1 40

      # now submit jobs with project
      set args "-P mytestproject $ts_config(product_root)/examples/jobs/sleeper.sh 10"
      set job_id [submit_job $args 1 60 "" $CHECK_USER]
      wait_for_jobstart $job_id "" 5
      lappend submitted_jobs $job_id
      set job_id [submit_job $args 1 60 "" $CHECK_FIRST_FOREIGN_SYSTEM_USER]
      wait_for_jobstart $job_id "" 5
      lappend submitted_jobs $job_id
      set job_id [submit_job $args 1 60 "" $CHECK_SECOND_FOREIGN_SYSTEM_USER]
      wait_for_jobstart $job_id "" 5
      lappend submitted_jobs $job_id

      # wait for all jobs to finish
      # we want to see usage to be booked into the sharetree
      foreach job_id $submitted_jobs {
         wait_for_jobend $job_id "" 60 0
      }

      # again verify checktree
      sge_share_mon sharetree
      share_mon_sharetree_check_node sharetree "/default/$CHECK_FIRST_FOREIGN_SYSTEM_USER" 1 10 1
      share_mon_sharetree_check_node sharetree "/default/$CHECK_SECOND_FOREIGN_SYSTEM_USER" 1 10 1
      share_mon_sharetree_check_node sharetree "/mytestproject/default/$CHECK_FIRST_FOREIGN_SYSTEM_USER" 1 40 1
      share_mon_sharetree_check_node sharetree "/mytestproject/default/$CHECK_SECOND_FOREIGN_SYSTEM_USER" 1 40 1
   }
}


#****** sge_share_mon/share_mon_permissions() ***************************************
#  NAME
#     share_mon_permissions() -- checks sge_share_mon qmaster access
#
#  SYNOPSIS
#     share_mon_permissions { }
#
#  FUNCTION
#     Verifies that sge_qmaster correctly handles access permissions
#     for the sge_share_mon client command:
#        - all users may call sge_share_mon
#        - must be on an admin or submit host
#*******************************************************************************
proc share_mon_permissions {} {
   global ts_config
   global CHECK_FIRST_FOREIGN_SYSTEM_USER
   global have_share_tree

   # check if we have an unused host, otherwise the test will fail anyway
   set non_cluster_host [host_conf_get_non_cluster_host]
   if {$non_cluster_host == ""} {
      # we have no non_cluster_host - skip this test
      # config error was already risen in host_conf_get_non_cluster_host()
      return
   }

   if {$have_share_tree} {
      # sge_share_mon must also work as non admin user user
      sge_share_mon sharetree "" $CHECK_FIRST_FOREIGN_SYSTEM_USER
   }

   # on a non admin/submit host, the request has to be rejected,
   # with and without sharetree
   set result [sge_share_mon sharetree $non_cluster_host "" 0]
   if {![check_for_non_cluster_host_error $result "any"]} {
      ts_log_severe "sge_share_mon request should have been rejected from non cluster host $non_cluster_host"
   }
}


#****** sge_share_mon/share_mon_sharetree_check_usage_time() ********************
#  NAME
#     share_mon_sharetree_check_usage_time() -- assert non-zero usage_time
#
#  SYNOPSIS
#     share_mon_sharetree_check_usage_time { sharetree_var node }
#
#  FUNCTION
#     Looks up the given node in the sge_share_mon output and reports a
#     severe error if its usage_time field is 0. Used by
#     share_mon_usage_time_stamp() to verify that user and project leaves
#     both carry a real timestamp once usage has been booked - the project
#     side was the bug fixed in CS-2317 (sge_share_mon previously printed
#     usage_time=0 for project-only nodes because the printer only read
#     UU_usage_time_stamp and never PR_usage_time_stamp).
#*******************************************************************************
proc share_mon_sharetree_check_usage_time {sharetree_var node} {
   upvar $sharetree_var sharetree

   set pos [lsearch -exact $sharetree(index) $node]
   if {$pos < 0} {
      ts_log_severe "couldn't find node $node in sge_share_mon output"
      return
   }

   set ts $sharetree($node,usage_time)
   if {$ts == 0} {
      ts_log_severe "node $node in sge_share_mon output has usage_time=0;\
                     usage was booked but the printer did not report the stamp. See CS-2317."
   }
}

#****** sge_share_mon/share_mon_usage_time_stamp() ******************************
#  NAME
#     share_mon_usage_time_stamp() -- verify non-zero usage_time on user and
#                                     project leaves
#
#  SYNOPSIS
#     share_mon_usage_time_stamp { }
#
#  FUNCTION
#     Regression coverage for CS-2317: prior to the fix in
#     sge_sharetree_printing.cc, sge_share_mon always reported
#     usage_time=0 for project leaves because the printer fell back to 0
#     when no user matched, instead of also reading PR_usage_time_stamp.
#
#     This check submits one plain user job and one project job (both as
#     CHECK_USER) so that:
#        - UU_usage_time_stamp gets set on the CHECK_USER object via the
#          plain user job (drives /CHECK_USER and any UPP leaf using it),
#        - PR_usage_time_stamp gets set on the mytestproject object via
#          the project job (drives /mytestproject).
#     After both jobs finish (and one share-tree tick has had a chance to
#     republish, STREE_TICK_INTERVAL=1 in the setup), it verifies that
#     sge_share_mon reports a non-zero usage_time on the user node, the
#     project node, and the UPP leaf.
#
#     The function uses its own job-id list so it is independent of
#     share_mon_sharetree().
#*******************************************************************************
proc share_mon_usage_time_stamp {} {
   get_current_cluster_config_array ts_config
   global CHECK_USER
   global have_share_tree
   global submitted_jobs

   if {!$have_share_tree} {
      return
   }

   set my_jobs {}

   # 1) plain user job - stamps UU_usage_time_stamp on CHECK_USER
   set user_args "$ts_config(product_root)/examples/jobs/sleeper.sh 5"
   set job_id [submit_job $user_args 1 60 "" $CHECK_USER]
   wait_for_jobstart $job_id "" 5
   lappend my_jobs $job_id
   lappend submitted_jobs $job_id

   # 2) project job - stamps PR_usage_time_stamp on mytestproject
   set project_args "-P mytestproject $ts_config(product_root)/examples/jobs/sleeper.sh 5"
   set job_id [submit_job $project_args 1 60 "" $CHECK_USER]
   wait_for_jobstart $job_id "" 5
   lappend my_jobs $job_id
   lappend submitted_jobs $job_id

   # Wait for our jobs to finish so worker booking has landed in
   # UU_/PR_usage_time_stamp before we read them via sge_share_mon.
   foreach jid $my_jobs {
      wait_for_jobend $jid "" 60 0
   }

   # Let the TET share-tree tick republish (STREE_TICK_INTERVAL pinned to 1 s
   # in the setup); a couple of ticks is plenty.
   sleep_for_seconds 3

   sge_share_mon sharetree
   share_mon_sharetree_check_usage_time sharetree "/$CHECK_USER"
   share_mon_sharetree_check_usage_time sharetree "/mytestproject"
   share_mon_sharetree_check_usage_time sharetree "/mytestproject/$CHECK_USER"
}

#****** sge_share_mon/share_mon_usage_in_spool() ********************************
#  NAME
#     share_mon_usage_in_spool() -- verify spool-side gating of usage booking
#
#  SYNOPSIS
#     share_mon_usage_in_spool { }
#
#  FUNCTION
#     Verifies that share-tree usage is booked into spooled user / project
#     objects exactly when a share tree is configured, and not otherwise.
#
#     This is the spooling-side regression coverage for the CS-1239 gate in
#     sge_book_finished_job_usage() and sge_sharetree_tick_handler(): both
#     short-circuit when no SHARETREE object exists in the master list, so
#     no UU_/PR_usage entries are produced and nothing reaches the spool.
#     Pre-CS-1239 the same behaviour fell out implicitly from the absence of
#     UU/PR objects in the master lists (see calc_usage.md); the gate makes
#     it explicit.
#
#     Level 0 (no share tree):
#        - explicitly add CHECK_USER so we have a UU object to inspect,
#        - submit a couple of short jobs as CHECK_USER,
#        - assert that the spooled user shows no usage attributes,
#        - delete CHECK_USER (level 0 cleanup does not touch users).
#
#     Level 1 (with share tree):
#        - CHECK_USER and the "mytestproject" project already exist,
#        - submit a user job and a project job (both as CHECK_USER),
#        - assert that both spooled objects show cpu, mem and io in usage.
#
#     STREE_SPOOL_INTERVAL is pinned to 1 s in the setup so the spool catches
#     up within seconds of job finish.
#*******************************************************************************
proc share_mon_usage_in_spool {} {
   get_current_cluster_config_array ts_config
   global CHECK_FIRST_FOREIGN_SYSTEM_USER
   global have_share_tree
   global submitted_jobs

   set sleeper "$ts_config(product_root)/examples/jobs/sleeper.sh 5"
   set my_jobs {}

   set job_id [submit_job $sleeper 1 60 "" $CHECK_FIRST_FOREIGN_SYSTEM_USER]
   wait_for_jobstart $job_id "" 5
   lappend my_jobs $job_id
   lappend submitted_jobs $job_id

   if {$have_share_tree} {
      set job_id [submit_job "-P mytestproject $sleeper" 1 60 "" $CHECK_FIRST_FOREIGN_SYSTEM_USER]
      wait_for_jobstart $job_id "" 5
      lappend my_jobs $job_id
      lappend submitted_jobs $job_id
   }

   foreach jid $my_jobs {
      wait_for_jobend $jid "" 60 0
   }

   # Wait long enough for the share-tree spool handler to drain the dirty
   # FIFOs. STREE_SPOOL_INTERVAL=1 s in the setup; a handful of seconds
   # gives the resume-drain cadence plenty of room.
   sleep_for_seconds 5

   set user_names [get_spooled_usage_names "user" $CHECK_FIRST_FOREIGN_SYSTEM_USER "usage"]

   if {$have_share_tree} {
      # Sharetree present -> worker booking must reach the spool.
      foreach attr {cpu mem io} {
         if {[lsearch -exact $user_names $attr] < 0} {
            ts_log_severe "spooled user $CHECK_FIRST_FOREIGN_SYSTEM_USER is missing \"$attr\" in usage list;\
                           share-tree usage booking did not reach the spool. Got: $user_names"
         }
      }

      # mytestproject is an interior node in the share tree (it has user-leaves
      # below it). In 9.2.x (CS-1239 worker-thread booking) the booking pipeline
      # writes PR_usage on the project object unconditionally whenever a job
      # submits with -P, so the spooled project carries cpu/mem/io even for
      # interior nodes; this is the shadow of UPP_usage on the user that the
      # sibling sharetree_usage_booking / sharetree_decay_periodic tests rely
      # on. Earlier branches (9.1.x) go through the scheduler order pipeline
      # and the foreign-user/auto-leaf case ends up spooling an empty
      # PR_usage, so the assertion is gated to 9.2.0+.
      set project_names [get_spooled_usage_names "project" "mytestproject" "usage"]
      if {[is_version_in_range "9.2.0"]} {
         foreach attr {cpu mem io} {
            if {[lsearch -exact $project_names $attr] < 0} {
               ts_log_severe "spooled project mytestproject is missing \"$attr\" in usage list;\
                              share-tree usage booking did not reach the spool. Got: $project_names"
            }
         }
      }
   } else {
      # No sharetree -> gate must suppress all booking; spool must stay clean.
      if {[llength $user_names] > 0} {
         set msg "spooled user $CHECK_FIRST_FOREIGN_SYSTEM_USER carries usage entries without a configured share tree:\
                  $user_names\n\
                  sge_book_finished_job_usage / sge_sharetree_tick_handler short-circuit was\
                  bypassed"
         # versions before 9.2.0 sometimes have entries with value 0.0 - skip the test for this setup
         if {[is_version_in_range "" "9.2.0"]} {
            ts_log_info $msg
         } else {
            ts_log_severe $msg
         }
      }
   }
}

