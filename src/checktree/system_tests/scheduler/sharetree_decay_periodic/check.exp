#****** system_tests/scheduler/sharetree_decay_periodic ****************************
#  NAME
#     sharetree_decay_periodic -- verify UU_/PR_/UPP_ usage decays over time
#
#  FUNCTION
#     Asserts that UU_/PR_/UPP_ usage values decay over wallclock time,
#     once via each of the two decay-rate knobs in sched_conf. The
#     populate-wait-ping-read flow is identical between the two check
#     functions; only the decay knob differs:
#
#     1) decay_via_halftime
#        Sets `halftime 1` (the smallest accepted value; the field is
#        in hours, so this is a 1-hour halflife) and clears
#        `halflife_decay_list`. With 1-hour halflife and a 90 s wait,
#        decay is small (~ 2 % using the Euler approximation in
#        ocs_Usage.cc:77) but must be present: the assertion is that
#        each post-wait value is strictly less than the corresponding
#        pre-wait value.
#
#     2) decay_via_halflife_decay_list
#        Sets `halflife_decay_list cpu=1`. The per-usage-attribute
#        halflife list takes values in *minutes* (and as a CULL Double
#        accepts fractional values, with a practical floor at ~ 0.7 min
#        before the Euler approximation goes negative). cpu=1 -> 1 min
#        halflife. Over a 90 s wait the theoretical exponential factor
#        is ~ 0.35; the Euler approximation produces smaller values.
#        The assertion is that each post-wait cpu is below 1/2 of the
#        corresponding pre-wait cpu.
#
#     Both check functions work on both the pre-CS-1239 tree (decay-
#     on-finish in the scheduler) and the post-CS-1239 tree (periodic
#     decay in the Timed Event Thread): after the wait period, the
#     check submits a "ping" sleep-0 job. On the pre-refactor tree the
#     ping triggers decay_and_sum_usage which catches up the decay
#     before summing in a negligible contribution. On the post-refactor
#     tree the TET task has already been decaying every few seconds
#     and the ping is a no-op. In both cases the post-wait sge_share_mon
#     read sees the decayed values.
#
#  BACKGROUND
#     Added as part of CS-1239. Both check functions must pass on the
#     unmodified tree and continue to pass after the refactor moves
#     usage decay out of the scheduler thread.
#***********************************************************************************

global check_name
global check_category
global check_description
global check_needs
global check_functions
global check_root_access_needs

set check_root_access_needs "yes"

set check_name              "sharetree_decay_periodic"
set check_category          "SCHEDULER SHARETREE VERIFIED"
set check_description(0)    "verify decay via halftime and halflife_decay_list"

set check_needs             "init_core_system"

set check_setup_function    sharetree_decay_periodic_setup
set check_cleanup_function  sharetree_decay_periodic_cleanup

set check_functions {}
lappend check_functions "decay_via_halftime"
lappend check_functions "decay_via_halflife_decay_list"

# -------- setup / cleanup ---------------------------------------------------------

proc sharetree_decay_periodic_setup {} {
   get_current_cluster_config_array ts_config
   global CHECK_PRODUCT_TYPE CHECK_USER
   global sharetree_decay_periodic_old_config
   global sharetree_decay_periodic_project

   if {$CHECK_PRODUCT_TYPE ne "sgeee"} {
      ts_log_config "test requires sgeee mode"
      return 99
   }

   set sharetree_decay_periodic_project "decay_periodic.prj"

   get_config sharetree_decay_periodic_old_config
   add_or_replace_array_param mc sharetree_decay_periodic_old_config "qmaster_params" "STREE_SPOOL_INTERVAL" "1"
   add_or_replace_array_param mc mc "execd_params"   "SHARETREE_RESERVED_USAGE" "true"
   set_config mc

   # Common scheduler config. The decay-rate knobs (halftime,
   # halflife_decay_list) are set per check function - see decay_via_*
   # below. flush_submit_sec / flush_finish_sec are left at their
   # default of 1 (immediate flush); 0 would *disable* flushing.
   set new_schedd(weight_tickets_share)      "10000"
   set new_schedd(weight_tickets_functional) "0"
   set new_schedd(usage_weight_list)         "cpu=1,mem=0,io=0"
   set new_schedd(schedule_interval)         "0:5:0"
   set_schedd_config new_schedd

   add_project $sharetree_decay_periodic_project

   del_sharetree
   stree_buffer_init stree
   stree_buffer_add_node stree "/$CHECK_USER" 100
   stree_buffer_add_node stree "/$sharetree_decay_periodic_project" 100
   stree_buffer_add_node stree "/$sharetree_decay_periodic_project/$CHECK_USER" 100
   stree_buffer_commit stree
}

proc sharetree_decay_periodic_cleanup {} {
   global sharetree_decay_periodic_old_config
   global sharetree_decay_periodic_project

   delete_all_jobs
   wait_for_end_of_all_jobs 60

   del_sharetree
   del_project $sharetree_decay_periodic_project

   reset_schedd_config
   reset_config sharetree_decay_periodic_old_config

   unset -nocomplain sharetree_decay_periodic_old_config
   unset -nocomplain sharetree_decay_periodic_project
}

# -------- helpers -----------------------------------------------------------------

#****** sharetree_decay_periodic/sharetree_decay_periodic_cpu() *******************
# Read sge_share_mon and return the cpu field for one sharetree node.
#**********************************************************************************
proc sharetree_decay_periodic_cpu {node} {
   sge_share_mon st
   if {[lsearch -exact $st(index) $node] < 0} {
      ts_log_severe "node $node not present in sge_share_mon output"
      return 0
   }
   return $st($node,cpu)
}

#****** sharetree_decay_periodic/sharetree_decay_periodic_run_one() ***************
# Submit one sleeper, optionally with -P project, wait until it has fully
# ended and the finish has been processed. sleep_time may be 0 (ping mode)
# or a positive duration for the initial populate-usage step. project may
# be "" for a user-only job, in which case UU_ is the only object touched.
#**********************************************************************************
proc sharetree_decay_periodic_run_one {sleep_time {project ""}} {
   get_current_cluster_config_array ts_config

   set args "-e /dev/null -o /dev/null"
   if {$project ne ""} {
      append args " -P $project"
   }
   append args " $ts_config(product_root)/examples/jobs/sleeper.sh $sleep_time"

   set job_id [submit_job $args]
   if {$job_id <= 0} {
      return -1
   }
   if {[wait_for_jobend $job_id "" 120 0 1] != 0} {
      return -1
   }
   trigger_scheduling
   sleep_for_seconds 5 "waiting for usage to be booked into sharetree"
   return 0
}

#****** sharetree_decay_periodic/sharetree_decay_periodic_measure() ***************
# Common populate-wait-ping-read flow used by both check functions.
#
# Clears all usage, runs one user-only job + one project job to populate
# UU_/PR_/UPP_, samples u0/p0/up0, waits 90 s with no submissions, pings
# with a sleep-0 project job to force a decay-and-sum on the pre-refactor
# tree (no-op on the post-refactor tree), samples u1/p1/up1, and returns
# the six values via upvar.
#
# Returns 1 on success, 0 if any step failed (in which case the caller
# should return early - errors have already been logged by the helpers).
#**********************************************************************************
proc sharetree_decay_periodic_measure {u0_var p0_var up0_var u1_var p1_var up1_var} {
   global CHECK_USER
   global sharetree_decay_periodic_project

   upvar 1 $u0_var u0 $p0_var p0 $up0_var up0
   upvar 1 $u1_var u1 $p1_var p1 $up1_var up1

   set user_node    "/$CHECK_USER"
   set project_node "/$sharetree_decay_periodic_project"
   set upp_node     "/$sharetree_decay_periodic_project/$CHECK_USER"

   # 1. populate UU_/PR_/UPP_ from a known-zero baseline.
   # Booking is per-leaf-of-(user, project): a user-only job populates UU_
   # only, a project job populates PR_ and UPP_ only (UU_ is decayed but
   # not summed into - see ocs_Usage.cc decay_and_sum_usage). To get all
   # three objects above zero we run one of each.
   start_sge_bin "qconf" "-clearusage"
   trigger_scheduling
   sleep_for_seconds 3 "waiting for cleared usage to settle"

   if {[sharetree_decay_periodic_run_one 10] != 0} {
      return 0
   }
   if {[sharetree_decay_periodic_run_one 10 $sharetree_decay_periodic_project] != 0} {
      return 0
   }
   set u0  [sharetree_decay_periodic_cpu $user_node]
   set p0  [sharetree_decay_periodic_cpu $project_node]
   set up0 [sharetree_decay_periodic_cpu $upp_node]
   ts_log_fine "initial usage: u=$u0 p=$p0 upp=$up0"
   if {$u0 <= 0 || $p0 <= 0 || $up0 <= 0} {
      ts_log_severe "expected UU_/PR_/UPP_ > 0 after populate, got u=$u0 p=$p0 upp=$up0"
      return 0
   }

   # 2. wait without any submissions so wallclock decay applies.
   sleep_for_seconds 90 "waiting for usage to decay"

   # 3. ping with a sleep-0 project job. On the pre-refactor tree the
   # finish triggers decay_and_sum_usage (decay catch-up + sum ~ 0). On
   # the post-refactor tree the TET task has already decayed and the
   # ping is a no-op. The project ping touches user, project and UPP_
   # objects so all three are guaranteed to be decay-stamped fresh.
   if {[sharetree_decay_periodic_run_one 0 $sharetree_decay_periodic_project] != 0} {
      return 0
   }

   set u1  [sharetree_decay_periodic_cpu $user_node]
   set p1  [sharetree_decay_periodic_cpu $project_node]
   set up1 [sharetree_decay_periodic_cpu $upp_node]
   ts_log_fine "after decay: u=$u1 p=$p1 upp=$up1"
   return 1
}

# -------- check functions ---------------------------------------------------------

#****** sharetree_decay_periodic/decay_via_halftime() *****************************
# Verifies that the top-level `halftime` field drives decay. Sets halftime
# to the smallest accepted value (1, i.e. 1 hour) and clears
# halflife_decay_list. The expected decay over the test's 90 s wait is
# small (~ 2 % using the Euler approximation in ocs_Usage.cc:77) - this
# check therefore asserts only the strict invariant "each post-wait value
# is less than the corresponding pre-wait value".
#**********************************************************************************
proc decay_via_halftime {} {
   # halftime is in hours; 1 is the smallest accepted value.
   # halflife_decay_list = NONE disables the per-attribute override so
   # decay falls back to the halftime-derived constant (ocs_Usage.cc:146-150).
   set sc(halftime)            "1"
   set sc(halflife_decay_list) "NONE"
   set_schedd_config sc

   if {![sharetree_decay_periodic_measure u0 p0 up0 u1 p1 up1]} {
      return
   }

   if {$u1 >= $u0} {
      ts_log_severe "UU_ did not decay via halftime: u0=$u0 u1=$u1, expected u1 < u0"
   }
   if {$p1 >= $p0} {
      ts_log_severe "PR_ did not decay via halftime: p0=$p0 p1=$p1, expected p1 < p0"
   }
   if {$up1 >= $up0} {
      ts_log_severe "UPP_ did not decay via halftime: up0=$up0 up1=$up1, expected up1 < up0"
   }
}

#****** sharetree_decay_periodic/decay_via_halflife_decay_list() ******************
# Verifies that the per-usage-attribute halflife_decay_list drives decay.
# Sets cpu=1 (= 1 minute halflife for cpu, the only attribute we measure).
# Over a 90 s wait the theoretical exponential factor is ~ 0.35; the
# Euler approximation produces a smaller (faster-decayed) value, so 1/2
# is a safe lower bound for the assertion.
#**********************************************************************************
proc decay_via_halflife_decay_list {} {
   # halflife_decay_list is in minutes per attribute (CULL Double).
   # cpu=1 -> 1 min halflife. Setting only cpu is enough since this is
   # the only attribute the test measures via sge_share_mon. halftime
   # is left at whatever the previous check function set; it does not
   # affect cpu because the per-attribute lookup wins at ocs_Usage.cc:146.
   set sc(halflife_decay_list) "cpu=1"
   set_schedd_config sc

   if {![sharetree_decay_periodic_measure u0 p0 up0 u1 p1 up1]} {
      return
   }

   set u_limit  [expr {$u0  / 2.0}]
   set p_limit  [expr {$p0  / 2.0}]
   set up_limit [expr {$up0 / 2.0}]
   if {$u1 >= $u_limit} {
      ts_log_severe "UU_ did not decay enough via halflife_decay_list: u0=$u0 u1=$u1, expected u1 < $u_limit"
   }
   if {$p1 >= $p_limit} {
      ts_log_severe "PR_ did not decay enough via halflife_decay_list: p0=$p0 p1=$p1, expected p1 < $p_limit"
   }
   if {$up1 >= $up_limit} {
      ts_log_severe "UPP_ did not decay enough via halflife_decay_list: up0=$up0 up1=$up1, expected up1 < $up_limit"
   }
}
