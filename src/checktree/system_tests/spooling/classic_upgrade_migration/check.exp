# DRAFT - optional coverage for the classic-spooling configuration migration
# (CS-2386). This is the ONE path not covered by any existing check: a full
# `inst_sge -upd` from an OLD cell whose bootstrap still carries the legacy
# two-argument `spooling_params` ("<common_dir>;<spool_dir>"). It exercises
# SelectNewSpooling in inst_upgrade.sh: the bootstrap is rewritten to the single
# spool-directory form, the obsolete common/{configuration,local_conf,
# sched_configuration} are removed, and the configuration is re-spooled into the
# spool-dir "configs" directory. (The existing "upgrade_config" check only
# replays config objects via load_config.sh and never touches the bootstrap.)
#
# ############################  NOT YET RUN  ###############################
# This check was authored without a testsuite to run it against and WILL need a
# validation pass. Confirm / adjust on first run:
#   1. Discovery: leaf dir under checktree with check.exp is picked up.
#   2. DESTRUCTIVE: `inst_sge -upd` restores the old cell over the running
#      cluster. check_cleanup reinstalls a fresh cluster so later checks keep a
#      clean cluster - verify the cleanup actually restores it, and consider
#      putting this check in an isolated run level so it does not disrupt others.
#   3. BIGGEST RISK - fixture/host mismatch: the recorded backups in
#      resources/backups/<ver>/ were captured on a specific host with specific
#      paths (e.g. v01701.fritz.box, /usr/local/testsuite/8000/qmaster). Replaying
#      a foreign backup's per-host config objects onto this cluster may error on
#      unknown hosts. If so, either (a) point at a fixture captured on THIS host,
#      or (b) rely on the upgrade's -on_error tolerance and assert only on the
#      global config + bootstrap migration, not the per-host objects.
#   4. UPGRADE_FROM_VERSION below must name a CLASSIC (two-arg) fixture that
#      exists under resources/backups/. Verify its cell/bootstrap has
#      "spooling_params  <path>;<path>".
#   5. Whether installer_do_upgrade_from_backup expects the current cluster to be
#      shut down first (it drives the interactive -upd; it may handle this).
# #########################################################################

# The old version to upgrade FROM. Must be a classic, pre-9.2 (two-arg) fixture
# present under resources/backups/. 9.1.0 is the newest pre-9.2 classic backup.
global classic_upgrade_from_version
set    classic_upgrade_from_version "9.1.0"

# define test's name and run level descriptions
set check_name            "classic_config_upgrade_migration"
set check_category        "COMPATIBILITY SYSTEM SPOOLING VERIFIED"
set check_description(0)  "full inst_sge -upd from an old two-arg classic cell migrates the bootstrap and config into the spool dir (CS-2386)"

set check_root_access_needs "yes"

# needs a running installed cluster to upgrade from / reinstall into
set check_needs           "init_core_system"

# The upgrade replaces the running cluster; always restore a fresh one afterwards
# so subsequent checks get a clean cluster (mirrors the upgrade_config check).
set check_cleanup_function "classic_config_upgrade_migration_cleanup"

set check_functions ""
lappend check_functions "classic_config_upgrade_migration_check"

## @brief true if $path exists on $host (as $user).
proc classic_upgrade_remote_exists {host user path} {
   start_remote_prog $host $user "test" "-e $path" prg_exit_state
   return [expr {$prg_exit_state == 0}]
}

## @brief Drive a full inst_sge -upd from an old two-arg classic backup and
#         assert the configuration migrated into the spool-dir "configs" layout.
#
# @return none (reports failures via ts_log_severe)
proc classic_config_upgrade_migration_check {} {
   get_current_cluster_config_array ts_config
   global CHECK_USER classic_upgrade_from_version

   if {$ts_config(spooling_method) != "classic"} {
      ts_log_fine "spooling_method is \"$ts_config(spooling_method)\" (not classic) - skipping"
      return
   }
   if {![is_version_in_range "9.2.0"]} {
      ts_log_fine "version under test < 9.2.0 - migration not applicable, skipping"
      return
   }

   set host   $ts_config(master_host)
   set common "$ts_config(product_root)/$ts_config(cell)/common"
   set spool  [get_spool_dir $host qmaster]

   set bckp_dir [installer_get_backup_dir $classic_upgrade_from_version]
   if {![classic_upgrade_remote_exists $host $CHECK_USER "$bckp_dir/cell/bootstrap"]} {
      ts_log_severe "no classic backup fixture at $bckp_dir (need a two-arg bootstrap to upgrade from) - cannot run migration test"
      return
   }

   # 1. run the full interactive inst_sge -upd from the old cell
   set ret [installer_do_upgrade_from_backup $bckp_dir]
   if {$ret != 0} {
      ts_log_severe "inst_sge -upd from $bckp_dir failed (exit $ret) - migration did not complete"
      return
   }

   # 2. bootstrap: spooling_params must now be a single path (no ';')
   set params [start_remote_prog $host $CHECK_USER "grep" "spooling_params $common/bootstrap" prg_exit_state]
   if {[string match "*;*" $params]} {
      ts_log_severe "bootstrap spooling_params still carries the legacy two-argument form after upgrade:\n$params"
   }

   # 3. configuration migrated into the spool-dir "configs" directory
   if {![classic_upgrade_remote_exists $host $CHECK_USER "$spool/configs/global"]} {
      ts_log_severe "global configuration not found at $spool/configs/global after upgrade"
   }

   # 4. obsolete common-dir configuration removed by the migration
   foreach old {configuration local_conf sched_configuration} {
      if {[classic_upgrade_remote_exists $host $CHECK_USER "$common/$old"]} {
         ts_log_severe "obsolete $common/$old still present after upgrade (guarded delete did not fire)"
      }
   }

   # 5. cluster is healthy after upgrade (job submission + CS-2352 hardening);
   #    installer_check_classic_spool_permissions (called inside) already checks
   #    the configs dir owner-only for >= 9.2.0.
   if {[installer_test_cluster_after_upgrade] != 0} {
      ts_log_severe "cluster not healthy after upgrade"
   }
}

## @brief Restore a fresh cluster after the (destructive) upgrade so subsequent
#         checks run against a clean, standard cluster.
proc classic_config_upgrade_migration_cleanup {} {
   installer_reinstall_fresh_cluster
}
