#****** finished_job_retention/load *******************************************
#  NAME
#     load -- CS-1908 SC9: retention at representative enabled scale
#
#  FUNCTION
#     Runs the retention feature under load using simulated execution hosts
#     (sim_eh.sh via the simhost_* helpers). Two runlevels:
#
#       * Runlevel 0 (functional smoke): 10 simulated hosts, ~150 jobs;
#         verifies retention scales past a modest N without regressions.
#         Fast to run, appropriate for the regular short-runlevel gate.
#
#       * Runlevel 100 (full scale): 200 simulated hosts and a
#         representative mix of workload shapes at production scale ---
#         1000 sequential jobs, 100 array jobs with 100 tasks each,
#         100 tight PE jobs with 4 tasks each. Not intended for the
#         short-runlevel gate; run explicitly when validating capacity.
#         (The plan's SC9 target is 1000/1000x1000/1000x4; the scale here
#         is a proportional subset that fits inside a bounded test
#         duration --- raise the count vars in the setup_level function
#         when running a full capacity certification.)
#
#     Both runlevels assert:
#       * qmaster completes all submissions without crash;
#       * every submitted job / task ends up retained under qstat -s f;
#       * qstat -s f stays responsive at the target scale;
#       * a drain trigger (finished_jobs_max = 0) removes the retained
#         set within a bounded window that scales with the retained
#         count and the configured per-tick prune batch.
#********************************************************************************

global check_name
global check_category
global check_description
global check_needs
global check_functions
global check_root_access_needs
global check_version_range

set check_root_access_needs "yes"
set check_version_range     "9.2.0"

set check_name              "retention_load"
set check_category          "QMASTER SIMHOST VERIFIED"
set check_description(0)    "CS-1908 SC9 retention load smoke (10 sim hosts, ~150 jobs)"
set check_description(100)  "CS-1908 SC9 retention load full scale (200 sim hosts, ~13k retained entries)"

set check_needs             "init_core_system"

set check_setup_function        fjr_load_setup
set check_setup_level_function  fjr_load_setup_level
set check_cleanup_function      fjr_load_cleanup

set check_functions {}
lappend check_functions "fjr_load_test"

# -------- setup / cleanup -----------------------------------------------------

proc fjr_load_setup {} {
   get_current_cluster_config_array ts_config
   global fjr_load_old_config fjr_load_hosts fjr_load_complex_backup

   if {[ge_has_feature "finished_job_retention"] == 0} {
      ts_log_config "CS-1908 finished-job retention not supported by this build (qstat -help lacks 'f' state)"
      return 99
   }

   delete_all_jobs
   wait_for_end_of_all_jobs

   get_config fjr_load_old_config
   get_complex fjr_load_complex_backup

   if {![simhost_init]} {
      # ts_log_config emitted by simhost_init
      return 99
   }

   # Host count is set per runlevel in fjr_load_setup_level; add there.
   set fjr_load_hosts {}
}

proc fjr_load_setup_level {} {
   get_current_cluster_config_array ts_config
   global CHECK_ACT_LEVEL fjr_load_hosts
   global fjr_load_n_hosts fjr_load_n_seq fjr_load_n_arrays fjr_load_n_array_tasks
   global fjr_load_n_tight fjr_load_n_tight_slots
   global fjr_load_keep_time fjr_load_max fjr_load_sweep_batch

   switch -exact $CHECK_ACT_LEVEL {
      0 {
         # Functional smoke — exercise every shape (sequential, array, tight
         # PE) at low scale so a regression in any code path is caught.
         set fjr_load_n_hosts        10
         set fjr_load_n_seq          100
         set fjr_load_n_arrays       1
         set fjr_load_n_array_tasks  50
         set fjr_load_n_tight        2
         set fjr_load_n_tight_slots  4
         set fjr_load_keep_time      "00:05:00"
         set fjr_load_max            "1000"
         set fjr_load_sweep_batch    "100"
      }
      100 {
         # Full-scale capacity test. Bump n_arrays * n_array_tasks toward
         # 1000 x 1000 = 1e6 when running SC9's full target (needs many
         # hours on typical hardware); values here are a proportional
         # subset that completes in a bounded window.
         set fjr_load_n_hosts        200
         set fjr_load_n_seq          1000
         set fjr_load_n_arrays       100
         set fjr_load_n_array_tasks  100
         set fjr_load_n_tight        100
         set fjr_load_n_tight_slots  4
         set fjr_load_keep_time      "01:00:00"
         set fjr_load_max            "100000"
         set fjr_load_sweep_batch    "500"
      }
      default {
         ts_log_config "unsupported runlevel $CHECK_ACT_LEVEL"
         return 99
      }
   }

   # Add the simulated hosts + queues. Do this in setup_level so the count
   # scales with the runlevel.
   set fjr_load_hosts [simhost_add $fjr_load_n_hosts "@simhosts"]

   set q(slots) $fjr_load_n_tight_slots
   if {$q(slots) < 4} { set q(slots) 4 }
   add_queue "sim.q"   "@simhosts" q

   # tight PE queue: add the PE first so the queue's pe_list reference
   # resolves cleanly on add_queue (add_queue otherwise fails because
   # load.pe does not exist yet at pe_list validation).
   if {$fjr_load_n_tight > 0} {
      set pe(slots)                    9999
      set pe(control_slaves)           "TRUE"
      set pe(job_is_first_task)        "TRUE"
      set pe(accounting_summary)       "FALSE"
      set pe(allocation_rule)          "\$round_robin"
      add_pe "load.pe" pe

      set qt(slots)     $fjr_load_n_tight_slots
      set qt(pe_list)   "load.pe"
      add_queue "tight.q" "@simhosts" qt
   }

   disable_queue "all.q"

   # Now enable retention. Do this after queues are up so the retention
   # config is live once the first jobs finish. Read the LIVE config
   # first so simhost_init's SIMULATE_EXECDS=TRUE (and any other
   # qmaster_params sub-keys set upstream) survive our merge — otherwise
   # add_or_replace_array_param would rebuild qmaster_params from an
   # empty base and evict SIMULATE_EXECDS, silently breaking the
   # simulated cluster.
   get_config live_config
   set new_config(finished_jobs_keep_time) $fjr_load_keep_time
   set new_config(finished_jobs_max)       $fjr_load_max
   add_or_replace_array_param new_config live_config  "qmaster_params" "FINISHED_JOBS_SWEEP_INTERVAL" "00:00:10" " "
   add_or_replace_array_param new_config new_config   "qmaster_params" "FINISHED_JOBS_SWEEP_BATCH"    $fjr_load_sweep_batch " "
   set_config new_config

   shutdown_and_restart_qmaster
   wait_for_load_from_all_queues 60 1 0
}

proc fjr_load_cleanup {} {
   get_current_cluster_config_array ts_config
   global fjr_load_old_config fjr_load_hosts fjr_load_complex_backup

   # Restore config first (retention off) so job cleanup doesn't have to
   # wait for a prune.
   reset_config fjr_load_old_config
   unset -nocomplain fjr_load_old_config

   delete_all_jobs
   wait_for_end_of_all_jobs

   catch {del_queue "sim.q"   "" 1 1}
   catch {del_queue "tight.q" "" 1 1}
   catch {del_pe    "load.pe"}
   catch {del_hostgroup "@simhosts"}
   if {[llength $fjr_load_hosts] > 0} {
      simhost_delete $fjr_load_hosts
   }
   reset_complex fjr_load_complex_backup
   enable_queue "all.q"

   unset -nocomplain fjr_load_hosts fjr_load_complex_backup
}

# -------- helpers -------------------------------------------------------------

proc fjr_load_retained_count {} {
   set out [start_sge_bin "qstat" "-s f -g d"]
   set n 0
   foreach l [split $out "\n"] {
      if {[regexp {^\s*[0-9]+\s+} $l]} { incr n }
   }
   return $n
}

proc fjr_load_wait_for_count_at_least {target timeout_seconds} {
   for {set i 0} {$i < $timeout_seconds} {incr i} {
      if {[fjr_load_retained_count] >= $target} { return 0 }
      sleep_for_seconds 2
   }
   return -1
}

proc fjr_load_wait_for_count_eq {target timeout_seconds} {
   for {set i 0} {$i < $timeout_seconds} {incr i} {
      if {[fjr_load_retained_count] == $target} { return 0 }
      sleep_for_seconds 2
   }
   return -1
}

# Log RSS of the qmaster process and total spool-dir size at a given
# checkpoint. Numbers feed the sge_conf(5) sizing notes — a full-scale
# runlevel-100 run should produce quotable memory/spool numbers.
proc fjr_load_log_sizing {label retained_count} {
   get_current_cluster_config_array ts_config
   global CHECK_USER

   # RSS of sge_qmaster (kB). Use the testsuite's get_qmaster_pid helper
   # so we do not have to shell-quote a compound command through
   # start_remote_prog. `ps -o rss= -p <pid>` returns just the RSS value.
   set qmaster_pid [get_qmaster_pid]
   set rss_kb "?"
   if {$qmaster_pid > 0} {
      set rss_out [start_remote_prog $ts_config(master_host) $CHECK_USER \
                   "ps" "-o rss= -p $qmaster_pid" prg_exit_state 60 0 "" "" 0 0]
      set trimmed [string trim $rss_out]
      if {[regexp {^\d+$} $trimmed]} { set rss_kb $trimmed }
   }

   # Spool dir size — covers whichever backend (classic files, BDB env,
   # Postgres client cache). Not perfect for Postgres (real data lives
   # in the DB), but a useful lower bound. `du -sk` prints "<kB>\t<path>"
   # so grep the leading numeric token.
   set spool_dir [get_qmaster_spool_dir]
   set spool_kb "?"
   if {[string length $spool_dir] > 0} {
      set du_out [start_remote_prog $ts_config(master_host) $CHECK_USER \
                  "du" "-sk $spool_dir" prg_exit_state 120 0 "" "" 0 0]
      if {[regexp {^\s*(\d+)} $du_out -> tok]} { set spool_kb $tok }
   }

   set per_entry_kb "?"
   if {$rss_kb ne "?" && $retained_count > 0} {
      set per_entry_kb [format "%.2f" [expr {double($rss_kb) / $retained_count}]]
   }

   ts_log_info "== sizing @ $label: retained=$retained_count qmaster_rss=${rss_kb}kB spool_dir=${spool_kb}kB per_entry_rss=${per_entry_kb}kB"
}

# Grab one retained jid from qstat -s f so a post-restart qstat -j probe
# can tell us whether the JB survived the reload but qstat -s f can't find
# it, or the JB was actually dropped.
proc fjr_load_sample_one_jid {} {
   set out [start_sge_bin "qstat" "-s f"]
   foreach l [split $out "\n"] {
      if {[regexp {^\s*([0-9]+)\s+} $l -> jid]} {
         return $jid
      }
   }
   return -1
}

# Measure qmaster startup time under a large retained set. Shutdown +
# restart while N entries live on the spool; time until qstat -s f
# returns the same count. Emit as a sizing measurement.
proc fjr_load_measure_startup {retained_count} {
   ts_log_fine "measure qmaster startup with $retained_count retained entries on spool"

   # Sample one retained jid so we can probe it with qstat -j after restart.
   set sample_jid [fjr_load_sample_one_jid]
   ts_log_info "sample retained jid before shutdown = $sample_jid"

   set t0 [clock milliseconds]
   shutdown_and_restart_qmaster
   # wait_for_load_from_all_queues is the harness's is-qmaster-alive signal
   # under simhost; use it here for restart-complete detection.
   wait_for_load_from_all_queues 120 1 0
   set t_up [expr {[clock milliseconds] - $t0}]

   # Immediate diagnostic: does qstat -j see the sampled jid?
   # * "does not exist" → the JB was dropped from master_job_list at reload
   #   (reload bug or unexpected setup-time cleanup)
   # * shows JAT detail → the JB is in memory but qstat -s f can't find it
   #   (filter/stored-procedure regression, or the retention config was
   #   cleared and the sweep pruned immediately)
   if {$sample_jid > 0} {
      set out [start_sge_bin "qstat" "-j $sample_jid" "" "" prg_exit_state]
      ts_log_info "post-restart qstat -j $sample_jid (exit=$prg_exit_state):\n$out"
   }

   # Log the current retention config in case something reset it.
   # `-all -inline -line` captures every matching line, not just the first.
   set out [start_sge_bin "qconf" "-sconf" "" "" prg_exit_state]
   set fjt [regexp -all -inline -line {^finished_jobs_.*$} $out]
   set qmp [regexp -all -inline -line {^qmaster_params.*$} $out]
   ts_log_info "post-restart config: [join $fjt {; }]  |  [join $qmp {; }]"

   # Compare all three qstat filter surfaces so we can localize the bug:
   #  * -s f  → retained-finished view (what we expect)
   #  * -s a  → all states including finished (belt-and-braces same view)
   #  * plain → no -s (default p|r|s, retained finished MUST NOT show)
   # If -s f = 0 but -s a > 0 we have a filter regression in the finished
   # branch. If both are 0 but plain also 0 with qstat -j working, we have
   # a mismatch between the retention state expected by the stored
   # procedures vs the actual JAT_status after reload.
   set out_f  [start_sge_bin "qstat" "-s f" "" "" exit_f]
   set out_a  [start_sge_bin "qstat" "-s a" "" "" exit_a]
   set out_pl [start_sge_bin "qstat" ""     "" "" exit_pl]
   set count_f  0
   set count_a  0
   set count_pl 0
   foreach l [split $out_f  "\n"] { if {[regexp {^\s*[0-9]+\s+} $l]} { incr count_f  } }
   foreach l [split $out_a  "\n"] { if {[regexp {^\s*[0-9]+\s+} $l]} { incr count_a  } }
   foreach l [split $out_pl "\n"] { if {[regexp {^\s*[0-9]+\s+} $l]} { incr count_pl } }
   ts_log_info "post-restart qstat counts: -s f=$count_f (exit=$exit_f); -s a=$count_a (exit=$exit_a); plain=$count_pl (exit=$exit_pl)"

   # After restart, wait for qstat -s f to return the full retained count
   # (reload finished). This is the number that matters for capacity
   # planning: "how long until qstat -s f is usable after a bounce."
   #
   # Two failure modes to catch and flag as regressions:
   #  (A) count never reaches the target — either reload dropped entries or
   #      qstat -s f can't see them;
   #  (B) count reaches some peak and then DECREASES — the sweep is pruning
   #      retained ja_tasks even though retention is enabled. Caught in
   #      CS-1908 U5: the qmaster startup used to bootstrap the sweep with
   #      sweep_all=1 unconditionally, draining retained entries on every
   #      restart regardless of the current retention config. R3/R4 require
   #      retained ja_tasks to survive across restarts.
   set target $retained_count
   set poll_start [clock milliseconds]
   set poll_timeout_ms 300000
   set observed -1
   set peak_observed 0
   set last_logged -1
   set decrease_detected 0
   while {[expr {[clock milliseconds] - $poll_start}] < $poll_timeout_ms} {
      set observed [fjr_load_retained_count]
      if {$observed != $last_logged} {
         ts_log_fine "  qstat -s f during reload wait: observed=$observed target=$target peak=$peak_observed"
         set last_logged $observed
      }
      if {$observed > $peak_observed} {
         set peak_observed $observed
      }
      # Detect (B) early: once we have SOME reloaded count, if the count
      # drops even once while below target, the sweep is illegally
      # draining retained entries. Bail out immediately with a severe
      # rather than waiting the full 5-min timeout.
      if {$peak_observed > 0 && $observed < $peak_observed && $observed < $target} {
         set decrease_detected 1
         break
      }
      if {$observed >= $target} { break }
      sleep_for_seconds 2
   }
   set t_qstat_ready [expr {[clock milliseconds] - $t0}]

   ts_log_info "== sizing @ startup: retained=$retained_count qmaster_up=${t_up}ms qstat_full=${t_qstat_ready}ms observed=$observed peak=$peak_observed"

   if {$decrease_detected} {
      ts_log_severe "retained count DECREASED after qmaster restart (peak=$peak_observed, observed=$observed, target=$target) — the retention sweep is draining retained ja_tasks despite retention being enabled (R3/R4 violation, see sge_thread_timer.cc bootstrap sweep_all flag)"
   } elseif {$observed < $target} {
      ts_log_severe "retained count did not reach target after ${poll_timeout_ms}ms (observed=$observed target=$target peak=$peak_observed) — reload from spool is incomplete or qstat -s f filter is broken; check post-restart diagnostics above"
   }
}

# -------- test ----------------------------------------------------------------

proc fjr_load_test {} {
   get_current_cluster_config_array ts_config
   global fjr_load_n_seq fjr_load_n_arrays fjr_load_n_array_tasks
   global fjr_load_n_tight fjr_load_n_tight_slots

   set expected 0

   # ---- sequential jobs -----------------------------------------------------
   ts_log_fine "submit $fjr_load_n_seq sequential jobs (-b y sleep 1)"
   for {set i 0} {$i < $fjr_load_n_seq} {incr i} {
      set jid [submit_job "-o /dev/null -j y -b y -q sim.q sleep 1"]
      if {$jid <= 0} {
         ts_log_severe "sequential submit failed at i=$i (rc=$jid)"
         return
      }
   }
   incr expected $fjr_load_n_seq

   # ---- array jobs ----------------------------------------------------------
   ts_log_fine "submit $fjr_load_n_arrays array jobs, $fjr_load_n_array_tasks tasks each"
   for {set i 0} {$i < $fjr_load_n_arrays} {incr i} {
      set jid [submit_job "-o /dev/null -j y -b y -q sim.q -t 1-$fjr_load_n_array_tasks sleep 1"]
      if {$jid <= 0} {
         ts_log_severe "array submit failed at i=$i (rc=$jid)"
         return
      }
   }
   incr expected [expr {$fjr_load_n_arrays * $fjr_load_n_array_tasks}]

   # ---- tight PE jobs -------------------------------------------------------
   # SIMULATE_EXECDS=TRUE means the execds do not actually launch the job
   # script — the qmaster fakes the finish after $1 seconds. So passing
   # a script path via pe_job.sh / pe_task.sh doesn't do anything useful
   # (and would parse the script path as an int, sim'ing a 0s runtime).
   # Just submit "sleep 1" as a binary; the retention machinery still sees
   # a real tight PE job with the requested slot allocation.
   if {$fjr_load_n_tight > 0} {
      ts_log_fine "submit $fjr_load_n_tight tight PE jobs, $fjr_load_n_tight_slots slots each"
      for {set i 0} {$i < $fjr_load_n_tight} {incr i} {
         set jid [submit_job "-o /dev/null -j y -b y -q tight.q -pe load.pe $fjr_load_n_tight_slots sleep 1"]
         if {$jid <= 0} {
            ts_log_severe "tight PE submit failed at i=$i (rc=$jid)"
            return
         }
      }
      incr expected $fjr_load_n_tight
   }

   ts_log_fine "expecting >=$expected retained entries once all jobs finish"

   # Wait for the retained count to reach the expected total. Timeout scales
   # with the count on the assumption of ~1 finish/sec/execd slot.
   set timeout [expr {$expected + 120}]
   if {[fjr_load_wait_for_count_at_least $expected $timeout] < 0} {
      set observed [fjr_load_retained_count]
      ts_log_severe "expected >=$expected retained entries within ${timeout}s, saw $observed"
      return
   }
   ts_log_fine "retained count reached >=$expected"

   # Peak-retention sizing measurements (feeds sge_conf(5) sizing notes).
   # Log RSS of sge_qmaster and total qmaster spool-dir size so a run at
   # scale produces reference numbers we can quote in the man page.
   fjr_load_log_sizing "peak_retention" $expected

   # Startup-time under retained load — the sge_conf(5) startup sizing
   # note claims BDB/Postgres backends are noticeably faster than classic
   # at reloading the retained set. Measure the actual number here.
   fjr_load_measure_startup $expected

   # Quick responsiveness probe: qstat -s p should return within a few
   # seconds even at scale (the retained set is only under -s f).
   set t0 [clock milliseconds]
   set out [start_sge_bin "qstat" "-s p" "" "" prg_exit_state]
   set elapsed [expr {[clock milliseconds] - $t0}]
   if {$prg_exit_state != 0} {
      ts_log_severe "qstat -s p failed under load (exit=$prg_exit_state)"
      return
   }
   if {$elapsed > 5000} {
      ts_log_severe "qstat -s p took ${elapsed}ms under load — qmaster responsiveness regressed"
   } else {
      ts_log_fine "qstat -s p round-trip under load: ${elapsed}ms"
   }

   # Trigger drain and wait for the retained set to go to 0. Timeout scales
   # with count and per-tick batch size. BOTH tunables must go to 0 to
   # enter the sweep's drain mode — leaving keep_time non-zero means the
   # sweep still bounds retention by age (fjr_load_keep_time is 5m for
   # runlevel 0, 1h for runlevel 100), so the test would time out waiting
   # for the age cap to expire instead of observing the immediate drain.
   ts_log_fine "trigger drain (finished_jobs_max=0, finished_jobs_keep_time=0) and wait for completion"
   set new_config(finished_jobs_max)       "0"
   set new_config(finished_jobs_keep_time) "0"
   set_config new_config
   set drain_start [clock seconds]

   # sweep_interval=10s per config; per-tick batch is per-level.
   global fjr_load_sweep_batch
   set expected_ticks [expr {($expected + $fjr_load_sweep_batch - 1) / $fjr_load_sweep_batch}]
   set drain_timeout  [expr {$expected_ticks * 10 + 120}]
   if {[fjr_load_wait_for_count_eq 0 $drain_timeout] < 0} {
      set remaining [fjr_load_retained_count]
      ts_log_severe "drain did not complete within ${drain_timeout}s; remaining=$remaining (expected 0)"
      return
   }
   set drain_elapsed [expr {[clock seconds] - $drain_start}]
   ts_log_fine "drain complete after ${drain_elapsed}s (~${expected_ticks} ticks)"

   # Post-drain sizing snapshot — proves memory and spool return to
   # baseline once the retained set is gone. Sits alongside the peak
   # measurement in the log for easy diff.
   fjr_load_log_sizing "post_drain" 0
}
