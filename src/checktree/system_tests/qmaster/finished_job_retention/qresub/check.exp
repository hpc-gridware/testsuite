#****** finished_job_retention/qresub *****************************************
#  NAME
#     qresub -- verify qresub of a retained-finished job succeeds (SC2)
#
#  FUNCTION
#     With retention enabled, a JAT that has reached JFINISHED must remain
#     addressable by qresub. Two scenarios:
#       (a) single retained finished job: qresub emits a new job-id, the new
#           job actually runs, and both jobs coexist.
#       (b) whole array retained (all tasks finished, all retained): qresub
#           emits a new job-id, the new array runs and completes.
#
#     Array *partial* retention (some tasks pruned, others retained) is
#     called out in the plan as an Open Question — its expected behavior is
#     to be nailed down separately. This check intentionally does not enforce
#     that shape yet.
#********************************************************************************

global check_name
global check_category
global check_description
global check_needs
global check_functions
global check_root_access_needs
global check_version_range

set check_root_access_needs "yes"
set check_version_range     "9.2.0"

set check_name              "retention_qresub"
set check_category          "QMASTER VERIFIED"
set check_description(0)    "CS-1908 qresub reachability of retained finished jobs"

set check_needs             "init_core_system"

set check_setup_function   fjr_qresub_setup
set check_cleanup_function fjr_qresub_cleanup

set check_functions {}
lappend check_functions "fjr_qresub_single_test"
lappend check_functions "fjr_qresub_array_test"
lappend check_functions "fjr_qresub_partial_array_test"

# -------- setup / cleanup -----------------------------------------------------

proc fjr_qresub_setup {} {
   get_current_cluster_config_array ts_config
   global fjr_qresub_old_config

   if {[ge_has_feature "finished_job_retention"] == 0} {
      ts_log_config "CS-1908 finished-job retention not supported by this build (qstat -help lacks 'f' state)"
      return 99
   }

   delete_all_jobs
   wait_for_end_of_all_jobs

   get_config fjr_qresub_old_config

   set new_config(finished_jobs_keep_time) "00:05:00"
   set new_config(finished_jobs_max)       "100"
   add_or_replace_array_param new_config fjr_qresub_old_config "qmaster_params" "FINISHED_JOBS_SWEEP_INTERVAL" "00:00:05" " "
   set_config new_config
   sleep_for_seconds 2 "let mconf settle"
}

proc fjr_qresub_cleanup {} {
   global fjr_qresub_old_config

   reset_config fjr_qresub_old_config
   unset -nocomplain fjr_qresub_old_config

   delete_all_jobs
   wait_for_end_of_all_jobs
}

# -------- helpers -------------------------------------------------------------

# Extract the new job-id from qresub's stdout. qresub emits a line matching
# "Your job <id> ...". Returns the id, or -1 if none found.
proc fjr_qresub_extract_jid {out} {
   if {[regexp {Your job(?:-array)?\s+(\d+)} $out -> jid]} {
      return $jid
   }
   return -1
}

# -------- test (a): single retained finished job ------------------------------

proc fjr_qresub_single_test {} {
   ts_log_fine "single: submit + wait for retention + qresub"

   set jid [submit_job "-o /dev/null -j y -b y sleep 1"]
   if {$jid <= 0} {
      ts_log_severe "initial submit failed (rc=$jid)"
      return
   }
   # wait_for_jobend returns as soon as the JAT flips to JFINISHED (plain
   # qstat excludes it) — right sync point under retention.
   wait_for_jobend $jid "" 60 0

   # Confirm the original job is retained (visible under -s f).
   set out [start_sge_bin "qstat" "-s f"]
   if {![regexp -line "^\\s*$jid\\s+" $out]} {
      ts_log_severe "original job $jid not retained (missing from qstat -s f):\n$out"
      return
   }

   set out [start_sge_bin "qresub" "$jid" "" "" prg_exit_state]
   if {$prg_exit_state != 0} {
      ts_log_severe "qresub $jid failed (exit=$prg_exit_state); output:\n$out"
      return
   }
   set new_jid [fjr_qresub_extract_jid $out]
   if {$new_jid < 0} {
      ts_log_severe "could not parse new job-id from qresub output:\n$out"
      return
   }
   ts_log_fine "qresub'd $jid -> $new_jid"

   wait_for_jobend $new_jid "" 60 0

   set out [start_sge_bin "qstat" "-s f"]
   if {![regexp -line "^\\s*$new_jid\\s+" $out]} {
      ts_log_severe "resubmitted job $new_jid not visible in qstat -s f:\n$out"
   }
   # And the original must still be retained (qresub does not evict).
   if {![regexp -line "^\\s*$jid\\s+" $out]} {
      ts_log_severe "original $jid no longer retained after qresub — retention should not evict on resubmit"
   }
}

# -------- test (b): whole array retained --------------------------------------

proc fjr_qresub_array_test {} {
   ts_log_fine "array: submit -t 1-3 + wait for retention + qresub"

   set jid [submit_job "-o /dev/null -j y -b y -t 1-3 sleep 1"]
   if {$jid <= 0} {
      ts_log_severe "array submit failed (rc=$jid)"
      return
   }
   wait_for_jobend $jid "" 60 0

   set out [start_sge_bin "qstat" "-s f -g d"]
   set rows 0
   foreach l [split $out "\n"] {
      if {[regexp "^\\s*$jid\\s+" $l]} { incr rows }
   }
   if {$rows != 3} {
      ts_log_severe "expected 3 retained JATs for array $jid, saw $rows; qstat -s f -g d output:\n$out"
      return
   }

   set out [start_sge_bin "qresub" "$jid" "" "" prg_exit_state]
   if {$prg_exit_state != 0} {
      ts_log_severe "qresub $jid (array) failed (exit=$prg_exit_state); output:\n$out"
      return
   }
   set new_jid [fjr_qresub_extract_jid $out]
   if {$new_jid < 0} {
      ts_log_severe "could not parse new array-id from qresub output:\n$out"
      return
   }
   ts_log_fine "qresub'd array $jid -> $new_jid"

   wait_for_jobend $new_jid "" 60 0
   set out [start_sge_bin "qstat" "-s f -g d"]
   set new_rows 0
   foreach l [split $out "\n"] {
      if {[regexp "^\\s*$new_jid\\s+" $l]} { incr new_rows }
   }
   if {$new_rows != 3} {
      ts_log_severe "expected 3 retained JATs for resubmitted array $new_jid, saw $new_rows; qstat -s f -g d output:\n$out"
   }
}

# -------- test (c): partially-retained array ----------------------------------
# Under a count-cap retention (max=3) some tasks of a -t 1-5 array will be
# pruned by the sweep before qresub runs. The qresub semantic ships as
# "resubmit the FULL original array" — JB_ja_structure carries the original
# 1-5 range and is untouched by the sweep, so the new job must run all
# 5 tasks even though only 3 were still retained at qresub-time.

proc fjr_qresub_partial_array_test {} {
   ts_log_fine "partial array: max=3 forces sweep to prune 2 of 5 tasks; qresub must still resubmit the full 1-5 range"

   # Tighten retention to max=3 so the sweep evicts 2 tasks after all 5 finish.
   # keep_time stays large (from setup) — this test isolates the count-bite.
   set new_config(finished_jobs_max) "3"
   set_config new_config
   sleep_for_seconds 2 "let mconf settle"

   set jid [submit_job "-o /dev/null -j y -b y -t 1-5 sleep 1"]
   if {$jid <= 0} {
      ts_log_severe "-t 1-5 submit failed (rc=$jid)"
      return
   }
   wait_for_jobend $jid "" 60 0

   # Wait for the sweep to prune down to exactly 3 retained.
   set retained_after_sweep -1
   for {set i 0} {$i < 20} {incr i} {
      set out [start_sge_bin "qstat" "-s f -g d"]
      set c 0
      foreach l [split $out "\n"] {
         if {[regexp "^\\s*$jid\\s+" $l]} { incr c }
      }
      if {$c == 3} {
         set retained_after_sweep 3
         break
      }
      sleep_for_seconds 1
   }
   if {$retained_after_sweep != 3} {
      ts_log_severe "expected retained count to settle at 3 (max=3) within 20s, still $c — count-cap sweep not firing"
      return
   }
   ts_log_fine "sweep pruned 5 -> 3 retained as expected"

   # qresub the partially-retained JB. Must succeed and yield a new array
   # covering the full original 1-5 range (JB_ja_structure preserved).
   set out [start_sge_bin "qresub" "$jid" "" "" prg_exit_state]
   if {$prg_exit_state != 0} {
      ts_log_severe "qresub $jid (partial array) failed (exit=$prg_exit_state); output:\n$out"
      return
   }
   set new_jid [fjr_qresub_extract_jid $out]
   if {$new_jid < 0} {
      ts_log_severe "could not parse new array-id from qresub output:\n$out"
      return
   }
   ts_log_fine "qresub'd partially-retained array $jid -> $new_jid"

   wait_for_jobend $new_jid "" 60 0

   # Give qacct's on-disk records a moment to flush. wait_for_jobend returns
   # as soon as JAT_status flips to JFINISHED; the accounting file write is
   # synchronous with sge_commit_job(_EE) but subject to reporting_params
   # flush_time slack — a small settle window keeps this stable.
   sleep_for_seconds 3 "let qacct records flush"

   set out [start_sge_bin "qacct" "-j $new_jid" "" "" prg_exit_state]
   if {$prg_exit_state != 0} {
      ts_log_severe "qacct -j $new_jid failed (exit=$prg_exit_state); output:\n$out"
      return
   }
   # qacct emits one section per completed task. Count sections whose
   # "jobnumber" matches $new_jid.
   set task_ids {}
   foreach line [split $out "\n"] {
      if {[regexp {^taskid\s+(\d+)} $line -> tid]} {
         if {[lsearch -exact $task_ids $tid] < 0} {
            lappend task_ids $tid
         }
      }
   }
   set n_tasks [llength $task_ids]
   if {$n_tasks != 5} {
      ts_log_severe "expected 5 tasks ran under resubmitted array $new_jid (full JB_ja_structure carried across), saw $n_tasks distinct task ids: $task_ids; qacct output:\n$out"
   }
}
